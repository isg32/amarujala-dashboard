DATABASE_URL=
NEON_AUTH_BASE_URL=
NEXT_PUBLIC_NEON_AUTH_URL=
NEON_AUTH_COOKIE_SECRET=
# Leave unset on Vercel. Set to "/dashboard" (no trailing slash) only when
# self-hosting behind nginx under a /dashboard sub-path — requires a rebuild
# to take effect (baked into the client bundle).
NEXT_PUBLIC_BASE_PATH=

PAYU_KEY=
PAYU_SALT=
SMS_API_USERNAME=
SMS_API_PASSWORD=
# Off by default — set to "true" only after manually testing the /pay flow.
PAYU_GATEWAY_ENABLED=false
